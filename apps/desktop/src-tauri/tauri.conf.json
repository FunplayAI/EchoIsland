{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EchoIsland",
  "version": "0.5.0",
  "identifier": "com.echoisland.desktop",
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "dmg": {
        "windowSize": {
          "width": 660,
          "height": 400
        },
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        }
      }
    }
  },
  "build": {
    "frontendDist": "../web"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "EchoIsland",
        "width": 420,
        "height": 80,
        "minWidth": 420,
        "minHeight": 80,
        "visible": false,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "shadow": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU5ODAzQTlENkVBNzZFNzkKUldSNWJxZHVuVHFBV1dhSXRPY3VycjhVQ2pyZXczNEtCemJpVTN3aFJkTU1zWmFxQTJPelhCN1EK",
      "endpoints": [
        "https://github.com/FunplayAI/EchoIsland/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
